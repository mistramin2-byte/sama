# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=uniabsence
DB_USER=postgres
DB_PASSWORD=

# JWT
# ⚠️ تم التصحيح: JWT_EXPIRES_IN → JWT_EXPIRES (ليتطابق مع routes/auth.js)
JWT_SECRET=uniabsence_jwt_secret_change_in_production_2024
JWT_EXPIRES=8h
REFRESH_SECRET=uniabsence_refresh_secret_change_in_production_2024
REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# CORS
FRONTEND_URL=http://localhost:3000